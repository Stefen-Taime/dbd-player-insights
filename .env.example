# =============================================================================
# Environment variables — copy to .env and fill in values
# NEVER commit .env to version control
# =============================================================================

# --- Snowflake ---------------------------------------------------------------
SNOWFLAKE_ACCOUNT=YOUR_ORG-YOUR_ACCOUNT
SNOWFLAKE_USER=YOUR_USER
SNOWFLAKE_PASSWORD=CHANGE_ME
SNOWFLAKE_DATABASE=DBD_ANALYTICS
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
SNOWFLAKE_ROLE=TRANSFORMER

# --- AWS (for S3 upload) ----------------------------------------------------
AWS_PROFILE=default
S3_BUCKET_NAME=dbd-telemetry-raw

# --- Airflow -----------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME

# --- Slack (optional) -------------------------------------------------------
# Channel: #macie-finds — get your webhook URL from Slack App settings
SLACK_WEBHOOK_URL=CHANGE_ME

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin

# --- Snowflake cost monitoring -----------------------------------------------
SNOWFLAKE_MONTHLY_BUDGET=10
