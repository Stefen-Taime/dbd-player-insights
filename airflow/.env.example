# Airflow environment variables — copy to .env and fill in values
# NEVER commit .env to version control

# Fernet key for encrypting connections/variables
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME

# Snowflake (used by DAGs via env vars, not Airflow connections for simplicity)
SNOWFLAKE_ACCOUNT=YOUR_ORG-YOUR_ACCOUNT
SNOWFLAKE_USER=YOUR_USER
SNOWFLAKE_PASSWORD=CHANGE_ME
SNOWFLAKE_DATABASE=DBD_ANALYTICS
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
SNOWFLAKE_ROLE=TRANSFORMER

# Slack webhook URL for alerts — channel: #macie-finds
SLACK_WEBHOOK_URL=CHANGE_ME

# Airflow UID (Linux only)
AIRFLOW_UID=1000
