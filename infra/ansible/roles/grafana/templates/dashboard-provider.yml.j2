# =============================================================================
# Dashboard provisioning — scans /var/lib/grafana/dashboards for JSON files
# =============================================================================
apiVersion: 1

providers:
  - name: DBD Player Insights
    orgId: 1
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: true
    options:
      path: /var/lib/grafana/dashboards
      foldersFromFilesStructure: false
