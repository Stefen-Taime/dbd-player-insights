# =============================================================================
# Airflow 3.x environment variables — generated by Ansible
# =============================================================================

AIRFLOW__CORE__EXECUTOR={{ airflow_executor }}
AIRFLOW__CORE__FERNET_KEY={{ airflow_fernet_key }}
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Airflow 3.x: SimpleAuthManager — define admin user
# Passwords are stored in passwords.json (bind-mounted into container)
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:admin

AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30

# Snowflake connection (used by DAGs via environment variables)
SNOWFLAKE_ACCOUNT={{ snowflake_account }}
SNOWFLAKE_USER={{ snowflake_user }}
SNOWFLAKE_PASSWORD={{ snowflake_password }}
SNOWFLAKE_DATABASE={{ snowflake_database }}
SNOWFLAKE_WAREHOUSE={{ snowflake_warehouse }}
SNOWFLAKE_ROLE={{ snowflake_role }}

# Slack webhook for alerts
SLACK_WEBHOOK_URL={{ slack_webhook_url }}

# UID for file permissions (Linux)
AIRFLOW_UID=1000
