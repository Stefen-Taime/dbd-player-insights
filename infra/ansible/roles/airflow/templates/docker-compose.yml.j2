# =============================================================================
# Airflow 3.x Docker Compose — LocalExecutor (single-machine, no Celery/Redis)
# Key changes from 2.x: api-server replaces webserver, dag-processor is separate
# Generated by Ansible — do not edit manually on the host
# =============================================================================

x-airflow-common: &airflow-common
  image: {{ airflow_image }}
  env_file: .env
  environment:
    _PIP_ADDITIONAL_REQUIREMENTS: "dbt-snowflake==1.9.2 dbt-expectations==0.10.7"
    DBT_PROFILES_DIR: /home/airflow/.dbt
    AIRFLOW__CORE__INTERNAL_API_URL: http://airflow-api-server:8080
  volumes:
    - ./dags:/opt/airflow/dags
    - ./logs:/opt/airflow/logs
    - ./plugins:/opt/airflow/plugins
    - ./config:/opt/airflow/config
    - ./passwords.json:/opt/airflow/simple_auth_manager_passwords.json.generated
    - /opt/dbt/project:/opt/dbt
    - /opt/dbt/profiles:/home/airflow/.dbt
  depends_on:
    postgres:
      condition: service_healthy
  restart: unless-stopped

services:
  # ---------------------------------------------------------------------------
  # Postgres metadata database
  # ---------------------------------------------------------------------------
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: airflow
      POSTGRES_PASSWORD: airflow
      POSTGRES_DB: airflow
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U airflow"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # ---------------------------------------------------------------------------
  # Airflow 3.x: API Server (replaces the old webserver)
  # ---------------------------------------------------------------------------
  airflow-api-server:
    <<: *airflow-common
    command: api-server
    ports:
      - "{{ airflow_api_server_port }}:8080"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080/api/v2/version || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

  # ---------------------------------------------------------------------------
  # Airflow 3.x: DAG Processor (now a separate component)
  # ---------------------------------------------------------------------------
  airflow-dag-processor:
    <<: *airflow-common
    command: dag-processor
    healthcheck:
      test: ["CMD-SHELL", "airflow jobs check --job-type DagProcessorJob --hostname $(hostname) || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

  # ---------------------------------------------------------------------------
  # Airflow scheduler (LocalExecutor — runs tasks in-process)
  # ---------------------------------------------------------------------------
  airflow-scheduler:
    <<: *airflow-common
    command: scheduler
    healthcheck:
      test: ["CMD-SHELL", "airflow jobs check --job-type SchedulerJob --hostname $(hostname) || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

  # ---------------------------------------------------------------------------
  # Airflow triggerer (for deferrable operators)
  # ---------------------------------------------------------------------------
  airflow-triggerer:
    <<: *airflow-common
    command: triggerer
    healthcheck:
      test: ["CMD-SHELL", "airflow jobs check --job-type TriggererJob --hostname $(hostname) || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

  # ---------------------------------------------------------------------------
  # One-shot init: migrate DB + create admin user
  # ---------------------------------------------------------------------------
  airflow-init:
    <<: *airflow-common
    entrypoint: /bin/bash
    command:
      - -c
      - |
        airflow db migrate
    restart: "no"

volumes:
  postgres_data:
