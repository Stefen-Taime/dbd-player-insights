# Grafana environment — copy to .env and fill in values
GRAFANA_ADMIN_PASSWORD=admin

# Snowflake credentials (used by provisioned datasource)
SNOWFLAKE_ACCOUNT=YOUR_ORG-YOUR_ACCOUNT
SNOWFLAKE_USER=YOUR_USER
SNOWFLAKE_PASSWORD=CHANGE_ME
SNOWFLAKE_DATABASE=DBD_ANALYTICS
SNOWFLAKE_WAREHOUSE=ANALYTICS_WH
SNOWFLAKE_ROLE=ANALYST
